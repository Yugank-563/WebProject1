<% layout("layouts/boilerplate") -%>

<style>
    .wishlist-header {
        padding: 1rem 0;
        border-bottom: 1px solid #eee;
        margin-bottom: 2rem;
    }
    .wishlist-title {
        font-weight: 800;
        color: #222;
        letter-spacing: -1px;
    }
    .empty-wishlist {
        padding: 5rem 0;
        text-align: center;
        background: #f9f9f9;
        border-radius: 2rem;
        border: 2px dashed #ddd;
    }
    .card-v4 {
        border: none !important;
        border-radius: 1.2rem !important;
        overflow: hidden;
        transition: all 0.3s ease;
        margin-bottom: 2rem;
    }
    .card-v4:hover {
        transform: translateY(-5px);
    }
    .card-img-v4 {
        height: 250px;
        object-fit: cover;
        border-radius: 1.2rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    .price-tag {
        font-weight: 700;
        color: #222;
    }
    .location-text {
        color: #717171;
        font-size: 0.9rem;
    }
</style>

<div class="container mt-4">
    <div class="wishlist-header">
        <h1 class="wishlist-title display-6 mb-1">Your Wishlist</h1>
        <p class="text-muted"><%= wishlist.length %> saved places</p>
    </div>

    <% if(wishlist.length > 0) { %>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            <% for(let listing of wishlist) { %>
                <div class="col">
                    <div class="card-v4 h-100 position-relative">
                        <a href="/listings/<%= listing.slug || listing.id %>" class="text-decoration-none">
                            <img src="<%= listing.image.url %>" class="card-img-v4 w-100" alt="<%= listing.title %>">
                            <div class="mt-3">
                                <h6 class="fw-bold text-dark mb-1 text-truncate"><%= listing.title %></h6>
                                <p class="location-text mb-1"><%= listing.location %>, <%= listing.country %></p>
                                <p class="price-tag mb-0">₹<%= listing.price.toLocaleString() %> <span class="fw-normal text-muted small">/ day</span></p>
                            </div>
                        </a>
                        <!-- Quick Remove button -->
                        <div class="position-absolute top-0 end-0 m-3" style="z-index: 10;">
                            <form action="/listings/<%= listing.id %>/wishlist?from=wishlist" method="POST">
                                <button class="btn btn-white btn-sm rounded-circle shadow-sm p-2" style="background: white;" title="Remove from wishlist">
                                    <i class="fa-solid fa-heart text-danger fs-5"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    <% } else { %>
        <div class="empty-wishlist">
            <i class="fa-regular fa-heart display-1 text-muted mb-4"></i>
            <h2 class="fw-bold">Your wishlist is empty</h2>
            <p class="text-muted mb-4">Save your favorite places to keep track of them here.</p>
            <a href="/listings" class="btn btn-danger btn-lg px-5 rounded-pill fw-bold">Start Exploring</a>
        </div>
    <% } %>
</div>
