<% layout("layouts/boilerplate") -%>

<div class="row mt-3">
    <div class="col-8 offset-2">  
        <h4 class="mb-2"><%= listing.title %></h4>

        <div class="card shadow mb-3">
            <img src="<%= listing.image.url %>" alt="listing-image" class="card-img-top show-page-img">
            <div class="card-body">
                <!-- <h5 class="card-title fw-bold mb-2"><%= listing.title %></h5> -->
                <small><i class="text-muted fw-semibold">Ownered by: <%= listing.owner.username %></i></small>
                <p class="card-text mb-2"><%= listing.description %></p>
                <p class="card-text text-success fw-semibold">&#8377; <%= listing.price.toLocaleString() %></p>
                <p class="card-text">
                    <small class="text-muted"><%= listing.location %>, <%= listing.country %></small>
                </p>
            </div>
        </div>

        <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
            <div class="d-flex gap-2 mt-2">
                <a href="/listings/<%= listing.id %>/edit" class="btn edit-btn mb-2 mb-md-0">Edit</a>
                <form action="/listings/<%= listing.id %>?_method=DELETE" method="POST">
                    <button class="btn btn-outline-secondary mb-2 mb-md-0" onclick="return confirm('Are you sure to delete this listing?')">Delete</button>
                </form>
            </div>
        <% } %>
    </div>
      

    <div class="mb-2 mt-3 col-8 offset-2">
        <% if(currUser){ %>
       <form action="/listings/<%=listing.id%>/reviews" method="POST" novalidate class = "needs-validation">
            <div>
                <label for = "rating" class="form-label">Rating:</label>
                <input  type="range" class="form-range" id="rating" name="review[rating]" min="1" max="5" step="1" value="<%= listing.rating %>">    
            </div>

            <div>
                <label for="comment" class="form-label">Comment:</label>
                <textarea class="form-control" id="comment" name="review[comment]" cols="30" rows="3" required><%= listing.comment %></textarea>
                <div class="invalid-feedback">
                    Please enter a comment.
                </div>
            </div>
            <button class="btn btn-outline-success mt-2">Add Review</button>
            <% } %>
       </form>

       <% if(listing.reviews.length > 0){ %>
        <hr/>
           <div class="row show-reviews">
                <h4 class="mb-2">Reviews:</h4>
                <% for(let review of listing.reviews) { %>
                    <div class="card col-5 mb-2 card-reviews">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-2">
                                <% let badgeClass = review.rating > 3 ? 'bg-success' : review.rating === 3 ? 'bg-warning' : 'bg-danger'; %>
                                <span class="badge <%= badgeClass %> me-2"><%= review.rating %> &#11088;</span>
                                <h6 class="mb-0">@<%= review.author.username %></h6>
                            </div>
                            <p class="card-text"><%= review.comment %></p>
                        </div>
                        <% if(currUser && currUser._id.equals(review.author._id)) { %>
                        <form action="/listings/<%=listing.id%>/reviews/<%=review.id%>?_method=DELETE" method="POST">
                            <button class="btn btn-outline-secondary review-del" onclick="return confirm('Are you sure to delete this review?')">Delete</button>
                        </form>
                        <% } %>
                    </div>
                <% } %>
           </div>
       <% } %>
</div> 
 