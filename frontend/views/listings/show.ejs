<% layout("layouts/boilerplate") -%>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-11">
            <!-- Listing Header -->
            <div class="mb-5 text-center">
                <h1 class="fw-bold text-dark mb-2" style="letter-spacing: -1px;"><%= listing.title %></h1>
                <div class="d-flex justify-content-center align-items-center gap-2">
                    <span class="badge bg-light text-danger px-3 py-2 rounded-pill border">
                        <i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %>
                    </span>
                </div>
            </div>

            <!-- Listing Main Content -->
            <div class="card border-0 shadow-lg overflow-hidden mb-5 rounded-5 listing-main-card">
                <div class="row g-0">
                    <div class="col-md-7 col-xl-8">
                        <div class="position-relative h-100">
                            <img src="<%= listing.image.url %>" alt="listing-image" class="img-fluid h-100 w-100 object-fit-cover show-page-img-v2">
                            <div class="position-absolute top-0 end-0 m-3">
                                <form action="/listings/<%= listing.id %>/wishlist" method="POST">
                                    <button class="btn btn-light btn-sm rounded-circle shadow-sm p-2 wishlist-btn" title="<%= (currUser && currUser.wishlist && currUser.wishlist.some(id => id.toString() === listing.id.toString())) ? 'Remove from wishlist' : 'Save to wishlist' %>">
                                        <i class="fa-<%= (currUser && currUser.wishlist && currUser.wishlist.some(id => id.toString() === listing.id.toString())) ? 'solid' : 'regular' %> fa-heart fs-5 <%= (currUser && currUser.wishlist && currUser.wishlist.some(id => id.toString() === listing.id.toString())) ? 'text-danger' : '' %>"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-5 col-xl-4 bg-white">
                        <div class="card-body p-4 p-xl-5 d-flex flex-column h-100">
                            <div class="d-flex align-items-center mb-4 p-3 bg-light rounded-4">
                                <div class="bg-dark text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 45px; height: 45px; font-weight: 600;">
                                    <%= listing.owner.username[0].toUpperCase() %>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">Hosted by <%= listing.owner.username %></h6>
                                    <small class="text-muted"><i class="fa-solid fa-shield-halved me-1"></i>Verified Host</small>
                                </div>
                            </div>
                            
                            <div class="mb-4">
                                <h5 class="fw-bold mb-3">About this space</h5>
                                <p class="card-text text-secondary mb-0" style="line-height: 1.7; font-size: 1.05rem;">
                                    <%= listing.description %>
                                </p>
                            </div>
                            
                            <div class="mt-auto border-top pt-4">
                                <div class="d-flex align-items-baseline mb-4">
                                    <span class="fs-1 fw-bold text-dark">&#8377;<%= listing.price.toLocaleString() %></span>
                                    <span class="text-muted ms-2 fs-5">/ day</span>
                                </div>
                                
                                <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
                                    <div class="d-flex gap-2">
                                        <a href="/listings/<%= listing.id %>/edit" class="btn btn-dark px-4 py-2 rounded-pill flex-grow-1">
                                            <i class="fa-solid fa-pen-to-square me-2"></i>Edit
                                        </a>
                                        <form action="/listings/<%= listing.id %>?_method=DELETE" method="POST" class="flex-grow-1">
                                            <button class="btn btn-outline-danger px-4 py-2 rounded-pill w-100" onclick="return confirm('Are you sure?')">
                                                <i class="fa-solid fa-trash me-2"></i>Delete
                                            </button>
                                        </form>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Enhanced Reviews Section -->
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm p-4 rounded-5 bg-white">
                        <h4 class="fw-bold mb-4">Share your experience</h4>
                        <% if(currUser){ %>
                            <form action="/listings/<%=listing.id%>/reviews" method="POST" novalidate class="needs-validation">
                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-uppercase text-muted mb-3">Rate your stay</label>
                                    <div class="rating-input-wrapper p-3 bg-light rounded-4 text-center">
                                        <input type="range" class="form-range custom-range-v2" id="rating" name="review[rating]" min="1" max="5" step="1" value="5">
                                        <div class="mt-2 text-warning fs-4" id="rating-stars-preview">
                                            <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label for="comment" class="form-label fw-bold small text-uppercase text-muted mb-2">Write a comment</label>
                                    <textarea class="form-control border-0 bg-light rounded-4 p-3 shadow-none" id="comment" name="review[comment]" rows="5" placeholder="What did you love about this place?" required></textarea>
                                    <div class="invalid-feedback ps-2">
                                        Please share a few words about your stay.
                                    </div>
                                </div>
                                <button class="btn btn-danger w-100 py-3 rounded-pill fw-bold shadow-sm">
                                    Post Review <i class="fa-solid fa-paper-plane ms-2"></i>
                                </button>
                            </form>
                        <% } else { %>
                            <div class="text-center py-5 px-3 bg-light rounded-5 border border-dashed">
                                <i class="fa-solid fa-lock fs-1 text-muted mb-3"></i>
                                <h5 class="fw-bold">Sign in to review</h5>
                                <p class="text-muted small mb-4">Sharing your experience helps others find the perfect place.</p>
                                <a href="/login" class="btn btn-dark px-4 py-2 rounded-pill fw-bold">Login Now</a>
                            </div>
                        <% } %>
                    </div>
                </div>

                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm p-4 rounded-5 bg-white">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-bold mb-0">Guest Reviews (<%= listing.reviews.length %>)</h4>
                            <% if(listing.reviews.length > 0) { %>
                                <div class="text-muted small fw-bold">
                                    <i class="fa-solid fa-star text-warning me-1"></i>
                                    <% 
                                        let avg = listing.reviews.reduce((acc, curr) => acc + curr.rating, 0) / listing.reviews.length;
                                    %>
                                    <%= avg.toFixed(1) %> Rating
                                </div>
                            <% } %>
                        </div>

                        <% if(listing.reviews.length > 0){ %>
                            <div class="row row-cols-1 row-cols-md-2 g-3">
                                <% for(let review of listing.reviews) { %>
                                    <div class="col">
                                        <div class="card h-100 border-0 bg-light rounded-4 p-3 review-card-v3">
                                            <div class="card-body p-2">
                                                <div class="d-flex justify-content-between mb-3">
                                                    <div class="d-flex align-items-center">
                                                        <div class="bg-white rounded-circle d-flex align-items-center justify-content-center shadow-sm me-2" style="width: 35px; height: 35px;">
                                                            <i class="fa-solid fa-user-check text-success" style="font-size: 0.8rem;"></i>
                                                        </div>
                                                        <div>
                                                            <h6 class="mb-0 fw-bold small">@<%= review.author.username %></h6>
                                                            <div class="text-muted mb-1" style="font-size: 0.65rem;"><%= review.createdAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></div>
                                                            <div class="text-warning" style="font-size: 0.7rem;">
                                                                <% for(let i=0; i<5; i++) { %>
                                                                    <i class="fa-<%= i < review.rating ? 'solid' : 'regular' %> fa-star"></i>
                                                                <% } %>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <% if(currUser && currUser._id.equals(review.author._id)) { %>
                                                        <form action="/listings/<%=listing.id%>/reviews/<%=review.id%>?_method=DELETE" method="POST">
                                                            <button class="btn btn-link text-danger p-0 border-0 shadow-none" onclick="return confirm('Remove review?')">
                                                                <i class="fa-solid fa-trash-can small"></i>
                                                            </button>
                                                        </form>
                                                    <% } %>
                                                </div>
                                                <p class="card-text text-secondary small mb-0 review-text-clamp">
                                                    <%= review.comment %>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                <% } %>
                            </div>
                        <% } else { %>
                            <div class="text-center py-5">
                                <img src="https://illustrations.popsy.co/gray/listening-to-music.svg" alt="no reviews" style="width: 150px; opacity: 0.5;">
                                <p class="text-muted mt-3 mb-0">No one has reviewed this space yet.</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Simple script to update stars preview on range input change
    const ratingInput = document.getElementById('rating');
    const starsPreview = document.getElementById('rating-stars-preview');
    
    if(ratingInput) {
        ratingInput.addEventListener('input', (e) => {
            const val = e.target.value;
            let stars = '';
            for(let i=0; i<5; i++) {
                stars += `<i class="fa-${i < val ? 'solid' : 'regular'} fa-star"></i>`;
            }
            starsPreview.innerHTML = stars;
        });
    }
</script>
 