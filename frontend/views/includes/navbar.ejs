<style>
    .navbar {
        background: #fff !important;
        padding: 0.8rem 0;
        box-shadow: 0 1px 12px rgba(0,0,0,0.05);
    }
    .navbar-brand {
        color: #fe424d !important;
        font-size: 1.5rem;
    }
    @media (max-width: 600px) {
        .navbar-collapse {
            position: absolute;
            right: 1.5rem;
            top: 4.5rem;
            background: #fff;
            border-radius: 1.2rem;
            padding: 0.5rem 0;
            box-shadow: 0 10px 40px rgba(0,0,0,0.15);
            border: 1px solid #eee;
            width: 180px; /* Even smaller */
            z-index: 1000;
        }
        .navbar-nav {
            text-align: right;
        }
        .nav-link {
            padding: 0.6rem 1rem !important; /* Thinner padding */
            border-bottom: 1px solid #f7f7f7;
            font-size: 0.9rem; /* Slightly smaller text */
        }
        .nav-link:last-child {
            border-bottom: none;
        }
        .explore-link {
            display: none !important; /* Hide Explore on mobile */
        }
    }
    /* Show horizontal navbar above 600px */
    @media (min-width: 601px) {
        .navbar-toggler {
            display: none !important;
        }
        .navbar-collapse {
            display: flex !important;
            flex-basis: auto;
            position: static; /* Reset from mobile absolute */
            width: auto;
            box-shadow: none;
            border: none;
            padding: 0;
            background: transparent;
        }
        .navbar-nav {
            flex-direction: row !important; /* Force horizontal */
            align-items: center;
        }
        .nav-link {
            border-bottom: none !important;
            margin-left: 1rem;
        }
    }
    /* Style the burger button itself */
    .navbar-toggler {
        border: 1px solid #ddd !important;
        border-radius: 50% !important; /* Circle instead of pill */
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 !important;
        box-shadow: 0 1px 2px rgba(0,0,0,0.08);
    }
</style>

<nav class="navbar navbar-expand-lg bg-body-light border-bottom sticky-top">
  <div class="container-fluid px-4">
    <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link explore-link" href="/listings">Explore</a>
      </div>
      
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/listings/new">Create Listing</a>
        <% if(!currUser){ %>
          <a class="nav-link" href="/signup"><strong>Sign up</strong></a>
          <a class="nav-link" href="/login"><strong>Log in</strong></a>  
        <% } %>
        <% if(currUser){ %>
          <a class="nav-link" href="/logout"><strong>Log out</strong></a>
        <% } %>
      </div>
    </div>
  </div>
</nav>